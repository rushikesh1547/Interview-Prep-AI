{
  "buildCommand": "cd interview-prep-ai && npm run build",
  "outputDirectory": "interview-prep-ai/dist",
  "routes": [
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
